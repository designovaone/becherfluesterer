# Neon Postgres Verbindungs-String (aus dem Neon Dashboard)
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"

# Geheimer Schlüssel zum Signieren der Session-Cookies.
# Mindestens 32 Zeichen. Zum Erzeugen:  openssl rand -hex 32
COOKIE_SECRET="bitte-ersetzen-mindestens-32-zeichen-zufaellig"

# Optional: Anzeigename des Turniers
NEXT_PUBLIC_TURNIER_NAME="Fußball-Weltmeisterschaft 2026"

# Admin-Recovery-Passwort (optional). Wird zusätzlich zum in /einrichten
# gesetzten Datenbank-Hash akzeptiert. Echten Wert nur in .env.local und in
# Vercel Environment Variables setzen, nicht hier.
ADMIN_PASSWORD="bitte-in-env-local-setzen"